# Tetris CLI Environment Variables
# Copy this file to .env and fill in your values

# HMAC keys for data integrity verification (minimum 16 bytes/128 bits)
# Generate secure random keys using: openssl rand -hex 32

# HMAC key for controls configuration file integrity
TETRIS_CONTROLS_HMAC_KEY=your_controls_hmac_key_here

# HMAC key for leaderboard data integrity
TETRIS_LEADERBOARD_HMAC_KEY=your_leaderboard_hmac_key_here

# HMAC key for save data integrity
TETRIS_SAVEDATA_HMAC_KEY=your_savedata_hmac_key_here

# GitHub token (if using GitHub integration)
# GITHUB_TOKEN=your_github_token_here
